def gameover_screen(win, clock, F_TITLE, F_MD, F_SM, winner, sfx):
    if winner == Player.RED:
        msg, col = "BOTJI MU LAWAN!", (255, 215, 60)
        sfx.play("win")
    else:
        msg, col = "KALAH SAMA BOT?", (100, 215, 255)
        sfx.play("lose")

    btn_menu   = pygame.Rect(WIDTH//2 - 230, 420, 200, 58)
    btn_replay = pygame.Rect(WIDTH//2 + 30,  420, 200, 58)
    t0 = time.time()

    while True:
        win.fill(C_BG)
        t = time.time() - t0
        draw_hex_grid(win, t, alpha=12)
        yo = int(math.sin(t * 2) * 8)

        gs = pygame.Surface((WIDTH, 120), pygame.SRCALPHA)
        gs.fill((*(col[:3]), 18))
        win.blit(gs, (0, 175+yo))

        center_text(win, F_TITLE, msg, 210 + yo, col)
        center_text(win, F_MD, "Permainan selesai!", 290, C_TEXT)
        center_text(win, F_SM, "Terima kasih telah bermain!", 330, C_TEXT2)

        mx, my = pygame.mouse.get_pos()

        hm = btn_menu.collidepoint(mx,my)
        hr = btn_replay.collidepoint(mx,my)

        pygame.draw.rect(win, (C_BTN_HOV if hm else C_BTN), btn_menu, border_radius=12)
        pygame.draw.rect(win, C_BORDER, btn_menu, 2, border_radius=12)
        lm = F_MD.render("Menu Utama", True, (255,255,255))
        win.blit(lm, lm.get_rect(center=btn_menu.center))

        pygame.draw.rect(win, (C_BTN_HOV if hr else C_BTN_ACT), btn_replay, border_radius=12)
        pygame.draw.rect(win, (100,255,140) if hr else C_BORDER, btn_replay, 2, border_radius=12)
        lr = F_MD.render("Main Lagi", True, (255,255,255))
        win.blit(lr, lr.get_rect(center=btn_replay.center))

        for ev in pygame.event.get():
            if ev.type == pygame.QUIT:
                pygame.quit(); sys.exit()
            if ev.type == pygame.KEYDOWN:
                if ev.key == pygame.K_ESCAPE: return "menu"
                if ev.key == pygame.K_r:      return "replay"
            if ev.type == pygame.MOUSEBUTTONDOWN:
                if btn_menu.collidepoint(ev.pos):   return "menu"
                if btn_replay.collidepoint(ev.pos): return "replay"

        pygame.display.flip()
        clock.tick(FPS)

# ──────────────────────────────────────────────────────────────
#  MAIN
# ──────────────────────────────────────────────────────────────
def main():
    pygame.init()
    pygame.mixer.pre_init(44100, -16, 2, 512)
    pygame.mixer.init()

    win   = pygame.display.set_mode((WIDTH, HEIGHT))
    pygame.display.set_caption("GAME DAM SIMPEL")
    clock = pygame.time.Clock()

    try:
        F_XL    = pygame.font.SysFont("Verdana", 54, bold=True)
        F_TITLE = pygame.font.SysFont("Verdana", 40, bold=True)
        F_MD    = pygame.font.SysFont("Verdana", 20, bold=True)
        F_SM    = pygame.font.SysFont("Verdana", 14)
    except:
        F_XL    = pygame.font.SysFont("Arial", 54, bold=True)
        F_TITLE = pygame.font.SysFont("Arial", 40, bold=True)
        F_MD    = pygame.font.SysFont("Arial", 20, bold=True)
        F_SM    = pygame.font.SysFont("Arial", 14)

    sfx        = SoundFX()
    state      = "menu"
    difficulty = Difficulty.MEDIUM
    game       = None

    while True:
        dt = clock.tick(FPS)

        # ── MENU ──────────────────────────────────────────────
        if state == "menu":
            difficulty, sfx_on = menu_screen(win, clock, F_TITLE, F_MD, F_SM, F_XL)
            sfx.enabled = sfx_on
            game        = Game(difficulty, sfx)
            game._refresh_must_eat()
            state       = "play"

        # ── PLAY ──────────────────────────────────────────────
        elif state == "play":
            game.update(dt)

            if game.ai_thinking:
                game.ai_thinking = False
                win.fill(C_BG)
                game.draw(win, F_SM, F_MD)
                ov = pygame.Surface((WIDTH, 42), pygame.SRCALPHA)
                ov.fill((0, 0, 0, 170))
                win.blit(ov, (0, BOARD_SIZE//2 - 21))
                think = F_MD.render("Sabar Kandaa .... ", True, (255, 210, 60))
                win.blit(think, think.get_rect(center=(WIDTH//2, BOARD_SIZE//2)))
                pygame.display.flip()
                pygame.event.pump()
                game.trigger_ai()

            for ev in pygame.event.get():
                if ev.type == pygame.QUIT:
                    pygame.quit(); sys.exit()
                if ev.type == pygame.KEYDOWN:
                    if ev.key == pygame.K_ESCAPE:
                        state = "menu"
                    if ev.key == pygame.K_p:
                        game.toggle_pause()
                    if ev.key == pygame.K_z or ev.key == pygame.K_u:
                        if not game.ai_pending and not game.anim:
                            game.undo()
                    if ev.key == pygame.K_r:
                        game = Game(difficulty, sfx)
                        game._refresh_must_eat()

                if ev.type == pygame.MOUSEBUTTONDOWN and ev.button == 1:
                    mx_, my_ = ev.pos
                    # Cek nav dulu
                    nav_action = game.handle_nav_click(ev.pos)
                    if nav_action == 'menu':
                        state = "menu"
                        continue
                    if nav_action in ('pause', 'undo'):
                        continue
                    # Klik papan
                    if my_ < BOARD_SIZE and not game.paused:
                        game.handle_click(my_ // SQ, mx_ // SQ)

            win.fill(C_BG)
            game.draw(win, F_SM, F_MD)

            pygame.display.flip()

            if game.winner_cache and not game.anim:
                state = "gameover"

        # ── GAMEOVER ──────────────────────────────────────────
        elif state == "gameover":
            action = gameover_screen(win, clock, F_TITLE, F_MD, F_SM,
                                     game.winner_cache, sfx)
            if action == "menu":
                state = "menu"
            elif action == "replay":
                game  = Game(difficulty, sfx)
                game._refresh_must_eat()
                state = "play"

if __name__ == "__main__":
    main()

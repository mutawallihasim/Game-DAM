def _draw_nav_btn(win, font, text, rect, bg, fg=(230,238,255), r=8, active=False, dim=False):
    """Tombol navigasi panel bawah — ramping, modern."""
    sh = pygame.Surface((rect.w+4, rect.h+4), pygame.SRCALPHA)
    pygame.draw.rect(sh, (0,0,0,60), (2,2, rect.w, rect.h), border_radius=r)
    win.blit(sh, (rect.x-1, rect.y-1))
    pygame.draw.rect(win, bg, rect, border_radius=r)
    if active:
        border_c = (120, 255, 140)
    elif dim:
        border_c = (35, 50, 80)
    else:
        border_c = (60, 100, 170)
    pygame.draw.rect(win, border_c, rect, 1, border_radius=r)
    lbl = font.render(text, True, fg)
    win.blit(lbl, lbl.get_rect(center=rect.center))

def center_text(win, font, text, y, color=C_TEXT):
    lbl = font.render(text, True, color)
    win.blit(lbl, lbl.get_rect(center=(WIDTH//2, y)))


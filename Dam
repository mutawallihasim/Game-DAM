def _make_sound(freq=440, duration=0.08, volume=0.3, wave="sine", decay=0.6):
    try:
        sr  = 44100
        t   = np.linspace(0, duration, int(sr * duration), endpoint=False)
        if wave == "sine":
            raw = np.sin(2 * np.pi * freq * t)
        elif wave == "square":
            raw = np.sign(np.sin(2 * np.pi * freq * t))
        else:
            raw = np.random.uniform(-1, 1, len(t))
        env = np.exp(-decay * np.arange(len(t)) / sr)
        raw *= env * volume
        pcm = (raw * 32767).astype(np.int16)
        stereo = np.column_stack([pcm, pcm])
        return pygame.sndarray.make_sound(stereo)
    except Exception:
        return None

class SoundFX:
    def __init__(self):
        self.enabled    = True
        self.snd_move   = _make_sound(320, 0.07, 0.25, "sine",   8)
        self.snd_eat    = _make_sound(180, 0.14, 0.38, "square", 5)
        self.snd_king   = _make_sound(560, 0.22, 0.32, "sine",   2)
        self.snd_win    = _make_sound(660, 0.32, 0.30, "sine",   2)
        self.snd_lose   = _make_sound(200, 0.32, 0.30, "sine",   3)
        self.snd_select = _make_sound(490, 0.05, 0.15, "sine",  12)
        self.snd_invalid= _make_sound(150, 0.06, 0.20, "square",10)
        self.snd_undo   = _make_sound(380, 0.10, 0.20, "sine",   6)
    def play(self, name):
        if not self.enabled: return
        snd = getattr(self, f"snd_{name}", None)
        if snd:
            try: snd.play()
            except: pass


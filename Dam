def draw_button(win, font, text, rect, bg, fg=(255,255,255), r=10):
    sh = pygame.Surface((rect.w+4, rect.h+4), pygame.SRCALPHA)
    pygame.draw.rect(sh, (0,0,0,80), (2,2, rect.w, rect.h), border_radius=r)

class Player(Enum):
    RED   = 1
    WHITE = 2
    def opponent(self):
        return Player.WHITE if self == Player.RED else Player.RED

class Difficulty(Enum):
    EASY   = ("Easy",   "Greedy",      1)
    MEDIUM = ("Medium", "Minimax",     4)
    HARD   = ("Hard",   "Alpha-Beta",  6)
    def __init__(self, label, algo, depth):
        self.label = label
        self.algo  = algo
        self.depth = depth


def draw_hex_grid(win, t, alpha=18):
    """Latar hexagon animasi ringan."""
    size = 38
    w3   = size * math.sqrt(3)
    h3   = size * 1.5
    surf = pygame.Surface((WIDTH, HEIGHT), pygame.SRCALPHA)
    for col_ in range(-1, int(WIDTH/w3)+2):
        for row_ in range(-1, int(HEIGHT/h3)+2):
            cx_ = col_ * w3 + (w3/2 if row_%2 else 0) + math.sin(t*0.3)*4
            cy_ = row_ * h3
            pts = [(cx_ + size*math.cos(math.radians(60*i+30)),
                    cy_ + size*math.sin(math.radians(60*i+30))) for i in range(6)]
            pygame.draw.polygon(surf, (255,255,255,alpha), pts, 1)
    win.blit(surf, (0,0))

def menu_screen(win, clock, F_TITLE, F_MD, F_SM, F_XL):
    diffs = list(Difficulty)
    sel   = Difficulty.MEDIUM
    sfx_on= True
    t0    = time.time()

    # Layout kartu difficulty
    card_w, card_h = 196, 120
    card_gap = 20
    total_w  = 3*card_w + 2*card_gap
    cards_x  = WIDTH//2 - total_w//2
    cards_y  = 310

    cards = {}
    for i, d in enumerate(diffs):
        cards[d] = pygame.Rect(cards_x + i*(card_w+card_gap), cards_y, card_w, card_h)

    start_rect = pygame.Rect(WIDTH//2 - 150, 480, 300, 54)
    sfx_rect   = pygame.Rect(WIDTH - 130, 16, 116, 34)

    icons = {
        Difficulty.EASY:   ("E", "Greedy",     "Cocok untuk pemula"),
        Difficulty.MEDIUM: ("M", "Minimax",     "Tantangan seimbang"),
        Difficulty.HARD:   ("H", "Alpha-Beta",  "Untuk yang ahli!"),
    }

    # Warna per difficulty
    diff_colors = {
        Difficulty.EASY:   (60, 170, 80),
        Difficulty.MEDIUM: (255, 165, 0),
        Difficulty.HARD:   (200, 70, 50),
    }

    while True:
        win.fill(C_BG)
        t = time.time() - t0

        # Background hex grid
        draw_hex_grid(win, t, alpha=12)

        # Gradient overlay
        grad = pygame.Surface((WIDTH, HEIGHT), pygame.SRCALPHA)
        for gy in range(HEIGHT):
            a = int(100 * (1 - gy/HEIGHT) ** 1.5)
            pygame.draw.line(grad, (10,16,28, a), (0, gy), (WIDTH, gy))
        win.blit(grad, (0,0))

        mx, my = pygame.mouse.get_pos()

        # ── Logo / Badge atas ──────────────────────────────
        # Lingkaran glow
        glow_a = int(28 + 10*math.sin(t*1.2))
        gs = pygame.Surface((500, 110), pygame.SRCALPHA)
        pygame.draw.ellipse(gs, (255,200,40, glow_a), (0,0,500,110))
        win.blit(gs, (WIDTH//2-250, 74))

        yo = int(math.sin(t*0.85) * 3)

        # Shadow judul
        lbl_sh = F_XL.render("DAM KAN MI", True, (0,0,0))
        win.blit(lbl_sh, lbl_sh.get_rect(center=(WIDTH//2+3, 120+yo+3)))
        lbl_title = F_XL.render("DAM KAN MI", True, C_GOLD)
        win.blit(lbl_title, lbl_title.get_rect(center=(WIDTH//2, 120+yo)))

        lbl_sub = F_MD.render("CATUR TAPI BEDA", True, (140, 190, 240))
        win.blit(lbl_sub, lbl_sub.get_rect(center=(WIDTH//2, 168)))

        # Garis dekoratif
        pygame.draw.line(win, (*C_GOLD, 120), (WIDTH//2-180, 192), (WIDTH//2+180, 192), 1)
        pygame.draw.circle(win, C_GOLD, (WIDTH//2, 192), 3)

        # ── Subtitle pilih kesulitan ─────────────────────
        lbl_choose = F_SM.render("— PILIH TINGKAT KESULITAN —", True, (100, 145, 200))
        win.blit(lbl_choose, lbl_choose.get_rect(center=(WIDTH//2, 272)))

        # ── Kartu Difficulty ──
        for d, rect in cards.items():
            icon, algo, desc = icons[d]
            is_sel  = (d == sel)
            hovered = rect.collidepoint(mx, my)
            dc      = diff_colors[d]

            # Shadow
            sh_s = pygame.Surface((card_w+8, card_h+8), pygame.SRCALPHA)
            pygame.draw.rect(sh_s, (0,0,0,90), (4,4,card_w,card_h), border_radius=16)
            win.blit(sh_s, (rect.x-2, rect.y-2))

            # Background kartu
            if is_sel:
                # Gradient biru
                card_surf = pygame.Surface((card_w, card_h), pygame.SRCALPHA)
                for cy_ in range(card_h):
                    t_c = cy_ / card_h
                    r_ = int(30 + 15 * t_c)
                    g_ = int(65 + 20 * t_c)
                    b_ = int(155 + 25 * t_c)
                    pygame.draw.line(card_surf, (r_, g_, b_, 255), (0, cy_), (card_w, cy_))
                win.blit(card_surf, rect.topleft)
                border_col = dc
                bw = 2
            elif hovered:
                pygame.draw.rect(win, (25, 50, 105), rect, border_radius=16)
                border_col = (90, 140, 220)
                bw = 2
            else:
                pygame.draw.rect(win, (14, 24, 52), rect, border_radius=16)
                border_col = (38, 62, 115)
                bw = 1

            # Glow jika terpilih
            if is_sel:
                pulse = int(4 + 2*math.sin(t*3))
                glow_s = pygame.Surface((card_w+pulse*2+4, card_h+pulse*2+4), pygame.SRCALPHA)
                pygame.draw.rect(glow_s, (*dc, 30), (0,0,card_w+pulse*2+4,card_h+pulse*2+4), border_radius=18)
                win.blit(glow_s, (rect.x-pulse-2, rect.y-pulse-2))

            # Accent bar atas kartu (warna per difficulty)
            if is_sel:
                bar_rect = pygame.Rect(rect.x+2, rect.y+2, card_w-4, 4)
                pygame.draw.rect(win, dc, bar_rect, border_radius=4)

            pygame.draw.rect(win, border_col, rect, bw, border_radius=16)

            # Ikon
            ico_col = dc if is_sel else (C_TEXT if hovered else (130,165,210))
            ico_lbl = F_MD.render(icon, True, ico_col)
            win.blit(ico_lbl, ico_lbl.get_rect(center=(rect.centerx, rect.y+32)))

            # Nama level
            nm_lbl = F_MD.render(d.label, True, (255,255,255) if is_sel else (200,215,240))
            win.blit(nm_lbl, nm_lbl.get_rect(center=(rect.centerx, rect.y+62)))

            # Algoritma
            alg_lbl = F_SM.render(algo, True, dc if is_sel else (80,115,170))
            win.blit(alg_lbl, alg_lbl.get_rect(center=(rect.centerx, rect.y+84)))

            # Deskripsi
            desc_lbl = F_SM.render(desc, True, (160,210,255) if is_sel else (65,95,145))
            win.blit(desc_lbl, desc_lbl.get_rect(center=(rect.centerx, rect.y+104)))

        # ── Tombol Mulai ──
        hover_s   = start_rect.collidepoint(mx, my)
        # Shadow tombol
        sh_btn = pygame.Surface((start_rect.w+8, start_rect.h+8), pygame.SRCALPHA)
        pygame.draw.rect(sh_btn, (0, 150, 60, 60), (4,4,start_rect.w,start_rect.h), border_radius=16)
        win.blit(sh_btn, (start_rect.x-2, start_rect.y-2))
        # Gradient tombol
        btn_surf = pygame.Surface((start_rect.w, start_rect.h), pygame.SRCALPHA)
        for by in range(start_rect.h):
            t_b = by / start_rect.h
            r_ = int(50 + 20 * t_b) if hover_s else int(38 + 10 * t_b)
            g_ = int(175 + 15 * t_b) if hover_s else int(152 + 10 * t_b)
            b_ = int(80 + 10 * t_b) if hover_s else int(65 + 10 * t_b)
            pygame.draw.line(btn_surf, (r_, g_, b_, 255), (0, by), (start_rect.w, by))
        win.blit(btn_surf, start_rect.topleft)
        border_c = (110,255,150) if hover_s else (70,200,110)
        pygame.draw.rect(win, border_c, start_rect, 2 if hover_s else 1, border_radius=14)

        start_lbl = F_MD.render("MULAI BERMAIN", True, (255,255,255))
        win.blit(start_lbl, start_lbl.get_rect(center=start_rect.center))

        # ── Tombol SFX (pojok kanan atas) ──
        sfx_lbl_txt = "SFX ON" if sfx_on else "SFX OFF"
        sfx_col = (28, 72, 45) if sfx_on else (65, 28, 28)
        sfx_hov = (40, 95, 60) if sfx_on else (90, 38, 38)
        _bg = sfx_hov if sfx_rect.collidepoint(mx, my) else sfx_col
        pygame.draw.rect(win, _bg, sfx_rect, border_radius=8)
        pygame.draw.rect(win, (60,100,70) if sfx_on else (100,50,50), sfx_rect, 1, border_radius=8)
        sfx_lbl = F_SM.render(sfx_lbl_txt, True, (200,240,200) if sfx_on else (240,180,180))
        win.blit(sfx_lbl, sfx_lbl.get_rect(center=sfx_rect.center))

        # ── Info bawah ──
        center_text(win, F_SM, "ESC = Keluar   ·   P = Jeda   ·   Z/U = Undo", 558, (48, 72, 118))

        # Versi
        ver_lbl = F_SM.render("v6.0", True, (38, 58, 95))
        win.blit(ver_lbl, (WIDTH-42, HEIGHT-20))

        for ev in pygame.event.get():
            if ev.type == pygame.QUIT:
                pygame.quit(); sys.exit()
            if ev.type == pygame.KEYDOWN:
                if ev.key == pygame.K_ESCAPE:
                    pygame.quit(); sys.exit()
                if ev.key == pygame.K_RETURN or ev.key == pygame.K_SPACE:
                    return sel, sfx_on
            if ev.type == pygame.MOUSEBUTTONDOWN:
                for d, r in cards.items():
                    if r.collidepoint(ev.pos):
                        sel = d
                if start_rect.collidepoint(ev.pos):
                    return sel, sfx_on
                if sfx_rect.collidepoint(ev.pos):
                    sfx_on = not sfx_on

        pygame.display.flip()
        clock.tick(FPS)

